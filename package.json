{
  "name": "ma-ville-notes",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && node tools/copy-404.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "data:build": "tsx tools/data-pipeline/src/main.ts",
    "data:validate": "tsx tools/data-pipeline/src/main.ts --strict",
    "data:sample": "tsx tools/data-pipeline/src/main.ts --departements 69,75",
    "test:data": "npm run test --workspace tools/data-pipeline"
  },
  "private": true,
  "workspaces": [
    "tools/data-pipeline"
  ],
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/router": "22.0.6",
    "@angular/service-worker": "22.0.6",
    "@supabase/supabase-js": "^2.110.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "@angular/ssr": "22.0.6",
    "@angular/platform-server": "22.0.6"
  },
  "devDependencies": {
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
