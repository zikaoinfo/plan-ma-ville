{
  "_readme": "URLs open data. geoCommunes = URL directe. BPE/SSMSI/Filosofi : résolution via l'API data.gouv.fr (slug `dataset` + `resource`/`resourceExclude`/`format`). Chaque run logge l'inventaire des ressources (job CI « Validate open data ») pour affiner les motifs. Réseau bloqué en sandbox → validation en CI. Voir docs/TODO.md §Phase 5.",
  "geoCommunes": "https://geo.api.gouv.fr/communes?fields=nom,code,codesPostaux,codeDepartement,population,centre&type=commune-actuelle,arrondissement-municipal&format=json",
  "bpe": {
    "dataset": "base-permanente-des-equipements",
    "format": "csv",
    "resource": "bpe-ensemble",
    "entry": "\\.csv$"
  },
  "securite": {
    "dataset": "bases-statistiques-communale-departementale-et-regionale-de-la-delinquance-enregistree-par-la-police-et-la-gendarmerie-nationales",
    "format": "csv.gz",
    "resource": "communale"
  },
  "filosofi": {
    "dataset": "revenu-des-francais-a-la-commune",
    "format": "csv",
    "resource": "commune",
    "valueCol": "^\\[DISP\\].*M[eé]diane"
  },
  "dvf": {
    "dataset": "statistiques-dvf",
    "format": "csv",
    "resource": "total"
  }
}
