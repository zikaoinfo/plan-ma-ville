{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.csr.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.svg",
          "/favicon.ico",
          "/index.html",
          "/index.csr.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/icons/**", "/**/*.(svg|png|jpg|webp|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "donnees-communes",
      "urls": ["/data/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": "4s",
        "maxSize": 220,
        "maxAge": "30d"
      }
    },
    {
      "name": "google-fonts",
      "urls": ["https://fonts.googleapis.com/**", "https://fonts.gstatic.com/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 40,
        "maxAge": "365d"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.__*", "!/**/*.__*/**"]
}
